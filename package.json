{
  "name": "nexus",
  "version": "0.11.0",
  "description": "NEXUS — All-in-one offline productivity desktop app",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-builder install-app-deps",
    "bundle-gs": "node scripts/bundle-ghostscript.js",
    "build-icons": "node scripts/build-icons.js"
  },
  "keywords": [],
  "author": {
    "name": "danangtomo",
    "email": "ajidanang9@gmail.com"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.9.0",
    "diff": "^9.0.0",
    "fast-formula-parser": "^1.0.19",
    "ffmpeg-static": "^5.3.0",
    "html-to-docx": "^1.8.0",
    "jsbarcode": "^3.12.3",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8"
  }
}
