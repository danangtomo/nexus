{
  "name": "nexus",
  "version": "0.16.0",
  "description": "NEXUS — Intent-driven offline productivity workspace",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-builder install-app-deps",
    "bundle-gs": "node scripts/bundle-ghostscript.js",
    "build-icons": "node scripts/build-icons.js",
    "build:licenses": "license-checker --production --json --out licenses.json",
    "postbuild": "npm run build:licenses"
  },
  "keywords": [],
  "author": {
    "name": "danangtomo",
    "email": "ajidanang9@gmail.com"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "@tiptap/extension-character-count": "^3.22.5",
    "@tiptap/extension-color": "^3.22.5",
